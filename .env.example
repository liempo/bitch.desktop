# Remote Hermes gateway
# Used when no saved connection config exists at:
#   $XDG_CONFIG_HOME/bitch/connection.json
#   ~/.config/bitch/connection.json
HERMES_DASHBOARD_URL=http://127.0.0.1:9119
HERMES_DASHBOARD_SESSION_TOKEN=replace-me

# Multi-profile remote setups use connection.json profile overrides instead of
# additional env vars. Run one Hermes dashboard backend per live profile/port:
#
# {
#   "mode": "remote",
#   "url": "http://127.0.0.1:9119",
#   "authMode": "token",
#   "token": "[REDACTED]",
#   "profiles": {
#     "crypto": {
#       "mode": "remote",
#       "url": "http://127.0.0.1:9121",
#       "authMode": "token",
#       "token": "[REDACTED]"
#     }
#   }
# }

# Homestation Beszel hub used by the MAIN dashboard host monitor.
# The renderer reads PocketBase collection records from this origin.
MONITORING_URL=http://homestation:8090

# CalDAV endpoint used by the CALENDAR route.
# Credentials stay behind the Tauri bridge; the renderer only sees status/events.
CALDAV_URL=https://calendar.example.test/dav/user/
CALDAV_USERNAME=replace-me
CALDAV_PASSWORD=replace-me
# CALDAV_DISPLAY_NAME=Personal
