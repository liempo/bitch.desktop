# Remote Hermes gateway
# Used when no saved connection config exists at:
#   $XDG_CONFIG_HOME/bitch.desktop/connection.json
#   ~/.config/bitch.desktop/connection.json
VITE_HERMES_DASHBOARD_URL=http://127.0.0.1:9119
BITCH_DASHBOARD_API_KEY=replace-me

# Multi-profile remote setups use connection.json profile overrides instead of
# additional env vars. Run one Hermes dashboard backend per live profile/port:
#
# {
#   "mode": "remote",
#   "url": "http://127.0.0.1:9119",
#   "authMode": "token",
#   "token": "[REDACTED]",
#   "profiles": {
#     "crypto": {
#       "mode": "remote",
#       "url": "http://127.0.0.1:9121",
#       "authMode": "token",
#       "token": "[REDACTED]"
#     }
#   }
# }

# Homestation host monitor sidecar
# Served by liempo/homestation docker/hermes host-monitor.
HOST_MONITOR_URL=http://homestation:61208
