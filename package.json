{
  "name": "bitch",
  "productName": "BITCH",
  "version": "0.1.0",
  "private": true,
  "description": "Remote-only Tauri + Svelte client for the Hermes dashboard gateway",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "bash scripts/rust-wrapper.sh tauri dev",
    "setup:rust": "bash scripts/rust-setup.sh",
    "build": "bash scripts/rust-wrapper.sh tauri build",
    "frontend:dev": "vite --host 127.0.0.1 --port 5173",
    "frontend:build": "vite build",
    "preview": "vite preview",
    "tauri": "bash scripts/rust-wrapper.sh tauri",
    "type-check": "svelte-check --tsconfig ./tsconfig.json --incremental",
    "lint": "eslint --concurrency off src/",
    "lint:fix": "eslint --concurrency off src/ --fix",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "test": "vitest run --maxWorkers=1 --no-file-parallelism",
    "test:watch": "vitest --maxWorkers=1 --no-file-parallelism",
    "prepare": "husky"
  },
  "dependencies": {
    "@schedule-x/calendar": "^3.7.3",
    "@schedule-x/svelte": "^3.0.0",
    "@schedule-x/theme-default": "^4.6.0",
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@threlte/core": "^8.5.16",
    "bits-ui": "^2.18.1",
    "dompurify": "^3.4.9",
    "ical.js": "^2.2.1",
    "marked": "^18.0.5",
    "temporal-polyfill": "0.3.0",
    "three": "^0.184.0",
    "tsdav": "^2.2.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/js": "^9.39.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2.5.0",
    "@types/three": "^0.184.1",
    "eslint": "^9.39.1",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "svelte": "^5.25.0",
    "svelte-check": "^4.1.6",
    "svelte-eslint-parser": "^1.8.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.45.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "knip": {
    "ignore": [
      ".cargo/**",
      ".rustup/**",
      "src-tauri/target/**",
      "src/lib/gateway/json-rpc-gateway.ts"
    ],
    "ignoreDependencies": [
      "@tauri-apps/cli"
    ]
  }
}
